{
  "name": "card-quest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-github-main": "vite build --base=/card-quest/ --outDir=dist",
    "build-github-develop": "vite build --base=/card-quest/develop/ --outDir=dist/develop",
    "validated-build": "vue-tsc -b && vite build",
    "deploy": "vite build && surge dist/ --domain card-quest.surge.sh",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "format": "prettier --write --experimental-cli src",
    "test": "vitest"
  },
  "dependencies": {
    "lodash.clonedeep": "^4.5.0",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/language-plugin-pug": "^3.2.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.27",
    "biome-tailwind-sorter": "^0.2.8",
    "fibers": "^5.0.3",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.8",
    "pug": "^3.0.3",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^25.5.0 || >=22.12.0"
  }
}
